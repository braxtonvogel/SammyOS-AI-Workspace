# Copy this file to .env.local and fill in the values

# Required — your nexus-analyzer backend URL
NEXT_PUBLIC_NEXUS_ANALYZER_URL=https://nexus-analyzer-three.vercel.app
NEXUS_ANALYZER_URL=https://nexus-analyzer-three.vercel.app

# Required — must match NEXUS_SECRET in your Vercel environment variables
NEXUS_SECRET=your-nexus-secret-here
