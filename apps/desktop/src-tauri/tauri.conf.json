{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "Sammy OS",
  "version": "0.1.0",
  "identifier": "com.sammy.os",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },

  "app": {
    "windows": [
      {
        "title": "Sammy OS",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],

    "security": {
      "capabilities": ["main-capability"]
    }
  }
}